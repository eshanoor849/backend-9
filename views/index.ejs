<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #e0eafc 0%, #cfdef3 100%);
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        /* main chat card – elegant container, heading now at the very top */
        .chat-app {
            width: 100%;
            max-width: 550px;
            background: rgba(255, 255, 255, 0.96);
            border-radius: 2rem;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.35), 0 1px 2px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            transition: all 0.2s ease;
            display: flex;
            flex-direction: column;
        }

        /* header area – now at the very top (above everything) with prominent design */
        .chat-header {
            background: #ffffff;
            padding: 1.25rem 1.8rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            position: relative;
            width: 100%;
        }

        .chat-header h1 {
            font-size: 1.85rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1F2B4E, #2c3e66, #1a2a44);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            letter-spacing: -0.3px;
            display: inline-block;
            margin: 0;
        }

        .chat-header .badge {
            display: inline-flex;
            align-items: center;
            background: #eef2ff;
            border-radius: 40px;
            padding: 4px 12px;
            margin-left: 12px;
            font-size: 0.7rem;
            font-weight: 600;
            color: #2c3e66;
            vertical-align: middle;
        }

        .chat-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 1.8rem;
            width: 70px;
            height: 3px;
            background: linear-gradient(90deg, #3b6eff, #a0c0ff);
            border-radius: 3px;
        }

        /* chat container - now directly under header */
        #chat-container {
            display: flex;
            flex-direction: column;
            flex: 1;
            background: #f9fafd;
        }

        /* chat box - beautiful scroll area, heading stays fixed on top */
        #chat-box {
            height: 420px;
            overflow-y: auto;
            padding: 1.5rem 1.2rem;
            display: flex;
            flex-direction: column;
            gap: 12px;
            background: #f9fafd;
            scroll-behavior: smooth;
        }

        /* custom scrollbar */
        #chat-box::-webkit-scrollbar {
            width: 5px;
        }

        #chat-box::-webkit-scrollbar-track {
            background: #e9eef3;
            border-radius: 10px;
        }

        #chat-box::-webkit-scrollbar-thumb {
            background: #b9c4da;
            border-radius: 10px;
        }

        /* message bubble base */
        .msg {
            max-width: 80%;
            padding: 12px 18px;
            border-radius: 26px;
            font-size: 0.95rem;
            line-height: 1.4;
            word-wrap: break-word;
            font-weight: 500;
            box-shadow: 0 1px 1px rgba(0, 0, 0, 0.05);
            transition: transform 0.1s ease;
            animation: fadeSlideUp 0.25s ease-out;
        }

        /* "me" messages (user) – right side, vibrant */
        .msg.me {
            background: linear-gradient(115deg, #2b5cff, #3a6eff);
            color: white;
            align-self: flex-end;
            border-bottom-right-radius: 6px;
            border-top-right-radius: 26px;
            border-top-left-radius: 26px;
        }

        /* "other" messages (received) – left side, soft light */
        .msg.other {
            background: #ffffff;
            color: #1e293b;
            align-self: flex-start;
            border-bottom-left-radius: 6px;
            border: 1px solid #e2edff;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.03);
        }

        /* subtle animation for new messages */
        @keyframes fadeSlideUp {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* input area – fresh, clean, and modern */
        #input-area {
            background: #ffffff;
            padding: 1rem 1.2rem 1.4rem 1.2rem;
            border-top: 1px solid #edf2f7;
            display: flex;
            gap: 12px;
            align-items: center;
            flex-wrap: wrap;
        }

        #msginput {
            flex: 1;
            padding: 14px 18px;
            border: 1.5px solid #e2e8f0;
            border-radius: 50px;
            font-size: 0.95rem;
            font-family: 'Inter', monospace;
            background: #fefefe;
            transition: all 0.2s;
            outline: none;
            color: #0f172a;
            font-weight: 500;
        }

        #msginput:focus {
            border-color: #3b6eff;
            box-shadow: 0 0 0 3px rgba(59, 110, 255, 0.2);
            background: white;
        }

        #msginput::placeholder {
            color: #94a3b8;
            font-weight: 400;
        }

        #btn {
            background: linear-gradient(95deg, #1f3b8c, #2b4eb5);
            border: none;
            padding: 12px 28px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.9rem;
            color: white;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
            letter-spacing: 0.3px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        #btn:hover {
            background: linear-gradient(95deg, #142f6e, #1f4296);
            transform: scale(0.97);
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        #btn:active {
            transform: scale(0.96);
        }

        /* empty state friendly */
        .empty-chat-mock {
            text-align: center;
            margin-top: 40px;
            color: #9aaec9;
            font-size: 0.85rem;
            font-weight: 500;
            background: #f1f5f9;
            width: fit-content;
            padding: 8px 18px;
            border-radius: 60px;
            align-self: center;
        }

        /* small responsive adjustments */
        @media (max-width: 480px) {
            .chat-app {
                max-width: 100%;
                border-radius: 1.5rem;
            }
            .msg {
                max-width: 90%;
                font-size: 0.9rem;
                padding: 10px 14px;
            }
            #btn {
                padding: 10px 22px;
            }
            .chat-header h1 {
                font-size: 1.5rem;
            }
        }
    </style>
   
       

</head>

<body>
   
   
<div class="chat-app">

    <div class="chat-header">
        <h1>Chatting App</h1>
    </div>
<div id="chat-container">
    <div id="chat-box"></div>

    <div id="input-area">
        <input type="text" id="msginput" placeholder="Enter your msg">
        <button id="btn">Send</button>
    </div>
</div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
     const socket = io();

const msgInput = document.querySelector("#msginput");
const sendBtn = document.querySelector("#btn");
const chatBox = document.querySelector("#chat-box");

// receive message from server
socket.on("message", (message) => {
    addMessage(message, "other");
});

// send message on button click
sendBtn.addEventListener("click", sendMessage);

// send message on Enter key
msgInput.addEventListener("keypress", (e) => {
    if (e.key === "Enter") {
        sendMessage();
    }
});

function sendMessage() {
    const message = msgInput.value.trim();

    if (!message) return;

    addMessage(message, "me");
    socket.emit("message", message);

    msgInput.value = "";
}

function addMessage(text, type) {
    const p = document.createElement("p");
    p.textContent = text;

    // add CSS classes
    p.classList.add("msg", type);

    chatBox.appendChild(p);

    // auto scroll
    chatBox.scrollTop = chatBox.scrollHeight;
}
   </script>
</body>
</html>